# ── FAL Tracking Worker — env ──────────────────────────────────────────────
# Copy to /opt/abstract27/env/fal-tracking.env on cx43 (gitignored, chmod 600).
# Uploads offline conversions via the Google **Data Manager API** (no dev token).
# Never commit real values.

# HTTP port (must match the Caddy upstream + healthcheck in docker-compose.yml)
PORT=3020

# ── Stripe (compte DÉDIÉ visites guidées) ──────────────────────────────────
# Required: webhook signing secret of the tours Stripe account.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Optional: only needed if we later enrich events via the Stripe API.
# Signature verification does NOT need it.
STRIPE_SECRET_KEY=

# ── Google Data Manager API ────────────────────────────────────────────────
# Operating account = the Google Ads account that receives the conversions
# (dashes are stripped automatically).
GOOGLE_ADS_CUSTOMER_ID=801-669-9315
# Login account = the manager (MCC) our OAuth user logs in through.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=480-962-3364
# The offline "tour_purchase" conversion action. Full resource name OR bare id —
# only the trailing numeric id (productDestinationId) is used.
# Created 2026-06-24 — type UPLOAD_CLICKS, category purchase, GBP:
GOOGLE_ADS_CONVERSION_ACTION=customers/8016699315/conversionActions/7660181261

# ── Tally lead webhook (Tours Privés — POST /webhook/tally) ─────────────────
# Signing secret of the Tally form 3l8vMk webhook (Integrations → Webhooks).
TALLY_SIGNING_SECRET=
# The "private_tour_lead" conversion action (category submit_lead_form, GBP).
# Full resource name OR bare id. Created 2026-06-30:
GOOGLE_ADS_LEAD_CONVERSION_ACTION=

# OAuth — a Google user with access to the Ads account/MCC.
# ⚠️ The refresh token MUST be minted with scope:
#    https://www.googleapis.com/auth/datamanager   (NOT adwords)
# Use scripts/get-refresh-token.mjs (already set to the datamanager scope).
# Also: enable the "Data Manager API" in the Google Cloud project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Set "true" for a safe dry-run (validates the upload without recording it).
GOOGLE_ADS_VALIDATE_ONLY=false

# ── Attribution gclid (tours publics — POST /attribution/link) ─────────────
# TicketingHub est une plateforme Stripe Connect + widget iframe cross-origin :
# impossible d'injecter le gclid dans les metadata Stripe. À la place, la
# thank-you page /cest-parti-… beacon {orderRef, gclid} ici ; le worker joint
# sur la référence "OR-xx" lue dans la description du PaymentIntent.
# Origine(s) autorisée(s) du beacon (séparées par des virgules).
ATTRIBUTION_ALLOWED_ORIGIN=https://francaisalondres.com
# Fichier de persistance ref→gclid (survit aux redéploiements). Nécessite un
# volume monté et inscriptible. Vide = purement en mémoire (OK, perd juste les
# correspondances en vol lors d'un restart).
ATTRIBUTION_STORE_PATH=/data/attribution.json
# Durée de vie d'une correspondance ref→gclid (ms). Défaut 6h.
ATTRIBUTION_TTL_MS=21600000
# Temps d'attente max du webhook Stripe pour le beacon gclid avant upload
# email-only (ms, sous le timeout webhook Stripe). Défaut 5s.
ATTRIBUTION_MATCH_WAIT_MS=5000

# ── Consent (EEA/UK) ───────────────────────────────────────────────────────
# GRANTED | DENIED | UNSPECIFIED → mapped to CONSENT_GRANTED / CONSENT_DENIED /
# CONSENT_STATUS_UNSPECIFIED. Defaults to GRANTED (paid booking + privacy policy).
GOOGLE_ADS_CONSENT_AD_USER_DATA=GRANTED
GOOGLE_ADS_CONSENT_AD_PERSONALIZATION=GRANTED
