# Authentication
DASHBOARD_PASSWORD=changeme

# Ghost Admin API (used by setup.ts — format: id:secret)
GHOST_ADMIN_KEY=your_id:your_secret

# Stripe
STRIPE_SECRET_KEY=sk_live_...
